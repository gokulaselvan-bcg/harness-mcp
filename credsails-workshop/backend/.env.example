# Copy to .env. With the placeholder below, the demo runs fully in deterministic STUB mode
# (no network, no cost). Drop in a real key to flip the hero agents to LIVE Claude calls.
ANTHROPIC_API_KEY=dummy-key-replace-me

# Optional: the model used in LIVE mode (ignored in stub mode). Override to the current Sonnet snapshot.
# ANTHROPIC_MODEL=claude-sonnet-4-5
