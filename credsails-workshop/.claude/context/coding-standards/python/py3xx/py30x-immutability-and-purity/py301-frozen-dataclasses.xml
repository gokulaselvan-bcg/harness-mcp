<rules id="CTX-CODING-STANDARDS-PYTHON-PY3XX-PY30X-IMMUTABILITY-AND-PURITY-PY301-FROZEN-DATACLASSES" title="py301 frozen dataclasses" kind="ruleset" version="2" updated="2026-02-20" status="active" source="py301-frozen-dataclasses.md">
  <rule id="PY301-FROZEN-DATACLASSES">
    <desc>Use `frozen=True` for dataclasses that shouldn't change.</desc>
    <examples>
      <example kind="good">`@dataclass(frozen=True) class Transaction: ...`</example>
    </examples>
    <related>
      <ref id="PY112-DATACLASS-TYPES"/>
      <ref id="PY300-IMMUTABILITY"/>
    </related>
  </rule>
</rules>
