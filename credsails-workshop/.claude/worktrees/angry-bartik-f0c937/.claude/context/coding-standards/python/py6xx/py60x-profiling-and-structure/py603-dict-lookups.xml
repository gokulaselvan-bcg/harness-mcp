<rules id="CTX-CODING-STANDARDS-PYTHON-PY6XX-PY60X-PROFILING-AND-STRUCTURE-PY603-DICT-LOOKUPS" title="py603 dict lookups" kind="ruleset" version="2" updated="2026-02-20" status="active" source="py603-dict-lookups.md">
