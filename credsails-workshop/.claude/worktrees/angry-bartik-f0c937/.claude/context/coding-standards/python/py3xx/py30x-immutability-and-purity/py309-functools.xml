<rules id="CTX-CODING-STANDARDS-PYTHON-PY3XX-PY30X-IMMUTABILITY-AND-PURITY-PY309-FUNCTOOLS" title="py309 functools" kind="ruleset" version="2" updated="2026-02-20" status="active" source="py309-functools.md">
